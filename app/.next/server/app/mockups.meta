{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/mockups/layout,_N_T_/mockups/page,_N_T_/mockups"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/mockups/__PAGE__",
    "/mockups",
    "/_index",
    "/_head"
  ]
}