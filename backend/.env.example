# ============================================
# UI Management System — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Server
PORT=5000
NODE_ENV=development          # production | development

# Database
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DB_NAME"
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ui_db
DB_CONNECTION_LIMIT=10

# Session (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=REPLACE_WITH_SECURE_RANDOM_64_BYTE_HEX

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_64_BYTE_HEX

# Frontend URL (used for CORS and OAuth redirect)
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
CALLBACK_URL=http://localhost:5000/api/auth/callback/google

# Email Service (Gmail App Password)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Google Drive Service Account
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=YOUR_FOLDER_ID

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Gemini AI (optional)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
